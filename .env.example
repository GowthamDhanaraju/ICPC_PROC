# ============================================================
# Batch Video Proctoring Pipeline — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# --- Application Environment ---
# Values: development | production
ENV=development

# --- AWS Credentials ---
# Leave blank to use IAM role (recommended for EC2/ECS deployments)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- S3 Bucket Names ---
SOURCE_S3_BUCKET=proctoring-incoming
RESULTS_S3_BUCKET=proctoring-results

# --- SQS (optional, for event-driven S3 trigger mode) ---
SQS_QUEUE_URL=

# --- Database ---
# SQLite (local dev): sqlite:///./proctoring.db
# PostgreSQL (production): postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./proctoring.db

# --- Celery / Redis (production worker queue) ---
# Leave blank to use the in-process thread queue (dev only)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- ML Models ---
# Set to False on the production server to run real YOLO/MediaPipe/Whisper models
MOCK_ML_MODELS=True

# --- Model Backend Selection ---
# Face detection: insightface (SCRFD, best) | yolo (YOLOv8s-face) | haar (fallback)
FACE_BACKEND=insightface
# Identity verification: arcface (InsightFace buffalo_sc, 99.5% LFW) | lbph
IDENTITY_BACKEND=arcface
# Head pose: 6drepnet (3.98° MAE, best) | mediapipe (decent, no download)
GAZE_BACKEND=6drepnet
# Voice activity: silero (97.4% F1, best) | rms (energy threshold, always works)
VAD_BACKEND=silero
# Speaker diarization: resemblyzer (GE2E, no token) | pyannote (best, needs token)
DIARIZATION_BACKEND=resemblyzer
# Whisper model size: tiny.en | base.en | small.en | medium.en
WHISPER_MODEL_SIZE=tiny.en

# --- HuggingFace Token (optional — enables pyannote diarization) ---
HUGGINGFACE_TOKEN=

# --- InsightFace GPU context (−1 = CPU, 0 = first GPU) ---
INSIGHTFACE_CTX_ID=-1

# --- Visual Detection Thresholds ---
FACE_CONFIDENCE_THRESHOLD=0.5
GADGET_CONFIDENCE_THRESHOLD=0.5
GAZE_AWAY_PITCH_THRESHOLD=15.0
GAZE_AWAY_YAW_THRESHOLD=20.0

# --- Adaptive Sampling ---
ADAPTIVE_SAMPLING_BASELINE_INTERVAL=1.6
ADAPTIVE_SAMPLING_DENSE_INTERVAL=0.4
ADAPTIVE_SAMPLING_SPARSE_INTERVAL=4.0
SCENE_CHANGE_THRESHOLD=0.02

# --- Webhook ---
WEBHOOK_TIMEOUT=10.0
WEBHOOK_MAX_RETRIES=3

# --- Testing ---
# Set to True to enable /test/* routes (never enable in production)
TESTING_MODE=False

# --- Worker ---
WORKER_CONCURRENCY=2

# --- Local Storage (fallback when S3 is not configured) ---
LOCAL_STORAGE_DIR=./storage
