# ============================================================
# Batch Video Proctoring Pipeline — Environment Configuration
# ============================================================

# --- Application Environment ---
ENV=development

# --- AWS Credentials (Left blank because we are using MinIO) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- S3 Bucket Names ---
# The bucket where videos are located and where results will be written
SOURCE_S3_BUCKET=proctortest
RESULTS_S3_BUCKET=proctortest

# --- MinIO Object Storage ---
MINIO_ENDPOINT=10.10.10.23:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=False

# --- Database ---
DATABASE_URL=sqlite:///./proctoring.db

# --- Celery / Redis (production worker queue) ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- ML Models ---
MOCK_ML_MODELS=False

# --- Model Backend Selection ---
FACE_BACKEND=insightface
IDENTITY_BACKEND=arcface
GAZE_BACKEND=6drepnet
VAD_BACKEND=silero
DIARIZATION_BACKEND=resemblyzer

# --- Visual Detection Thresholds ---
FACE_CONFIDENCE_THRESHOLD=0.5
GADGET_CONFIDENCE_THRESHOLD=0.5
GAZE_AWAY_PITCH_THRESHOLD=15.0
GAZE_AWAY_YAW_THRESHOLD=20.0

# --- Adaptive Sampling ---
ADAPTIVE_SAMPLING_BASELINE_INTERVAL=1.6
ADAPTIVE_SAMPLING_DENSE_INTERVAL=0.4
ADAPTIVE_SAMPLING_SPARSE_INTERVAL=4.0
SCENE_CHANGE_THRESHOLD=0.02

# --- Webhook ---
WEBHOOK_TIMEOUT=10.0
WEBHOOK_MAX_RETRIES=3

# --- Testing ---
TESTING_MODE=False

# --- Debug Features ---
# When True, generates an MP4 with bounding boxes/gaze lines and uploads it to MinIO
RENDER_OVERLAY_VIDEO=True

# --- Adaptive Sampling (Enforce 24 FPS) ---
# 1 / 24 = 0.0416 seconds
ADAPTIVE_SAMPLING_BASELINE_INTERVAL=0.0416
ADAPTIVE_SAMPLING_DENSE_INTERVAL=0.0416
ADAPTIVE_SAMPLING_SPARSE_INTERVAL=0.0416
